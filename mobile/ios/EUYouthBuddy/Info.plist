	<string>Allow $(PRODUCT_NAME) to access your location</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Pip uses your location to show EU opportunities and forms near you.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Hoppy needs your microphone so you can talk with it.</string>
	<key>NSMotionUsageDescription</key>
	<string>Allow $(PRODUCT_NAME) to detect your current motion activity</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Hoppy reads a photo of your ID to fill EU forms for you.</string>
	<key>RCTNewArchEnabled</key>
	<true/>
