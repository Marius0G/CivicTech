	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>eu.youthbuddy.app</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>exp+eu-youth-buddy</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>12.0</string>
