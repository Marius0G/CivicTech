# Copy to backend/.env and fill in. NEVER commit the real .env.
OPENAI_API_KEY=sk-...your-key...

# Optional: live web_search (Tavily). Without it, web_search degrades gracefully and the
# frog falls back to search_eu_info (the curated RAG corpus).
# TAVILY_API_KEY=tvly-...your-key...

# --- Auth: real per-user accounts via Supabase ------------------------------------------------
# Set ALL THREE to turn on real sign-in. When set, the backend REQUIRES a valid Supabase bearer
# token on /realtime, /tools, /docs and /chat, and stores each user's profile in the `profiles`
# table (see deploy/supabase-setup.sql). Leave them blank to stay in single demo-user mode.
# SUPABASE_URL and SUPABASE_ANON_KEY: Supabase Dashboard → Project Settings → API.
# SUPABASE_SERVICE_ROLE_KEY: same page, "service_role" secret — SERVER ONLY, never ships to app.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=eyJ...your-anon-key...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Optional overrides (sensible defaults in config.py):
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_REALTIME_VOICE=marin
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# CORS_ORIGINS=*
