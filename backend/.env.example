# Copy to backend/.env and fill in. NEVER commit the real .env.
OPENAI_API_KEY=sk-...your-key...

# Optional: live web_search (Tavily). Without it, web_search degrades gracefully and the
# frog falls back to search_eu_info (the curated RAG corpus).
# TAVILY_API_KEY=tvly-...your-key...

# Optional overrides (sensible defaults in config.py):
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_REALTIME_VOICE=marin
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# CORS_ORIGINS=*
